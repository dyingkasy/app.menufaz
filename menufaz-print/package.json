{
  "name": "menufaz-print",
  "version": "0.1.13",
  "description": "Menufaz Print - agente local Windows para impressao automatica com resiliencia operacional",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "iconv-lite": "0.6.3",
    "printer": "0.4.0"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.menufaz.print",
    "productName": "Menufaz Print",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/printer/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "deleteAppDataOnUninstall": true,
      "include": "installer.nsh"
    }
  }
}
