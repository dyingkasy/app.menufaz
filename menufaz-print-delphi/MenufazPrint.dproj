<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{A551378D-4477-4B07-9B3D-3A6F46217F8A}</ProjectGuid>
        <ProjectVersion>18.2</ProjectVersion>
        <FrameworkType>VCL</FrameworkType>
        <MainSource>MenufazPrint.dpr</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <TargetedPlatforms>1</TargetedPlatforms>
        <AppType>Application</AppType>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;Vcl;Vcl.Imaging;$(DCC_Namespace)</DCC_Namespace>
        <Icon_MainIcon>MenufazPrint.ico</Icon_MainIcon>
        <VerInfo_MajorVer>1</VerInfo_MajorVer>
        <VerInfo_MinorVer>0</VerInfo_MinorVer>
        <VerInfo_Release>0</VerInfo_Release>
        <VerInfo_Build>0</VerInfo_Build>
        <VerInfo_Keys>CompanyName=Menufaz;FileDescription=Menufaz Print;FileVersion=1.0.0.0;InternalName=MenufazPrint;LegalCopyright=Menufaz;OriginalFilename=MenufazPrint.exe;ProductName=Menufaz Print;ProductVersion=1.0.0</VerInfo_Keys>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win32)'!=''">
        <Platform>Win32</Platform>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>MenufazPrint</SanitizedProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1_Win32)'!=''">
        <CfgParent>Cfg_1</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <Version>7.0</Version>
        <DCC_DebugInformation>true</DCC_DebugInformation>
        <DCC_LocalDebugSymbols>true</DCC_LocalDebugSymbols>
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1_Win32)'!=''">
        <DCC_ExeOutput>.\Win32\Debug</DCC_ExeOutput>
        <DCC_DcuOutput>.\Win32\Debug</DCC_DcuOutput>
        <DCC_ObjOutput>.\Win32\Debug</DCC_ObjOutput>
        <DCC_HppOutput>.\Win32\Debug</DCC_HppOutput>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' And '$(Platform)'=='Win32'">
        <DCC_ExeOutput>.\Win32\Debug</DCC_ExeOutput>
        <DCC_DcuOutput>.\Win32\Debug</DCC_DcuOutput>
        <DCC_ObjOutput>.\Win32\Debug</DCC_ObjOutput>
        <DCC_HppOutput>.\Win32\Debug</DCC_HppOutput>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="MainForm.pas"/>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
</Project>
